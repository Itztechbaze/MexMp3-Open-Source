<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme — no action bar, pure black system bars -->
    <style name="Theme.MexMp3" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/pure_black</item>
        <item name="android:statusBarColor">@color/pure_black</item>
        <item name="android:navigationBarColor">@color/pure_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!--
        Splash screen theme: AndroidX SplashScreen API.
        The Activity is launched with this theme; after the splash the
        Theme.MexMp3 base theme is applied via postSplashScreenTheme.
    -->
    <style name="Theme.MexMp3.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/pure_black</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.MexMp3</item>
    </style>

</resources>
